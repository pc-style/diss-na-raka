{
  "type": "object",
  "properties": {
    "research_window": {
      "type": "object",
      "properties": {
        "start_local": { "type": "string" },
        "end_local": { "type": "string" },
        "timezone": { "type": "string" }
      },
      "required": ["start_local", "end_local", "timezone"],
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "properties": {
        "one_sentence": { "type": "string" },
        "current_or_final_total_pln": { "type": ["number", "null"] },
        "status_at_window_end": { "type": "string", "enum": ["ongoing", "ended", "unclear"] },
        "highest_verified_total_pln": { "type": ["number", "null"] },
        "highest_verified_total_time_local": { "type": ["string", "null"] },
        "highest_verified_total_time_utc": { "type": ["string", "null"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["one_sentence", "current_or_final_total_pln", "status_at_window_end", "highest_verified_total_pln", "highest_verified_total_time_local", "highest_verified_total_time_utc", "confidence", "notes"],
      "additionalProperties": false
    },
    "dashboard_patch": {
      "type": "object",
      "properties": {
        "dashboard": {
          "type": "object",
          "properties": {
            "totalRaisedPln": { "type": ["number", "null"] },
            "metadata": {
              "type": "object",
              "properties": {
                "lastUpdatedUtc": { "type": ["string", "null"] }
              },
              "required": ["lastUpdatedUtc"],
              "additionalProperties": false
            }
          },
          "required": ["totalRaisedPln", "metadata"],
          "additionalProperties": false
        }
      },
      "required": ["dashboard"],
      "additionalProperties": false
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "targetAmount": { "type": "number" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["achieved", "pending", "failed"] },
          "dateAchieved": { "type": ["string", "null"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "sources": { "$ref": "#/$defs/sources" }
        },
        "required": ["id", "targetAmount", "title", "description", "status", "dateAchieved", "confidence", "sources"],
        "additionalProperties": false
      }
    },
    "timelineEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "dateLocal": { "type": "string" },
          "relativeTime": { "type": "string" },
          "sortUtc": { "type": ["string", "null"] },
          "zrodlo": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            },
            "required": ["label", "url"],
            "additionalProperties": false
          },
          "participants": { "type": "array", "items": { "type": "string" } },
          "category": { "type": "string", "enum": ["core_event", "milestone_execution", "guest_appearance", "endurance_challenge", "scheduled_appearance"] },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "sources": { "$ref": "#/$defs/sources" }
        },
        "required": ["id", "dateLocal", "relativeTime", "sortUtc", "zrodlo", "participants", "category", "description", "tags", "confidence", "sources"],
        "additionalProperties": false
      }
    },
    "counter_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "amount_pln": { "type": "number" },
          "observed_at_local": { "type": ["string", "null"] },
          "observed_at_utc": { "type": ["string", "null"] },
          "source_label": { "type": "string" },
          "source_url": { "type": "string" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "notes": { "type": "string" }
        },
        "required": ["amount_pln", "observed_at_local", "observed_at_utc", "source_label", "source_url", "confidence", "notes"],
        "additionalProperties": false
      }
    },
    "donations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "donor": { "type": "string" },
          "amount_pln": { "type": ["number", "null"] },
          "type": { "type": "string", "enum": ["corporate", "individual", "celebrity", "brand", "unknown"] },
          "observed_at_local": { "type": ["string", "null"] },
          "observed_at_utc": { "type": ["string", "null"] },
          "description": { "type": "string" },
          "sources": { "$ref": "#/$defs/sources" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        },
        "required": ["donor", "amount_pln", "type", "observed_at_local", "observed_at_utc", "description", "sources", "confidence"],
        "additionalProperties": false
      }
    },
    "unverified_leads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "reason_unverified": { "type": "string" },
          "possible_sources": { "type": "array", "items": { "type": "string" } },
          "recommended_follow_up": { "type": "string" }
        },
        "required": ["claim", "reason_unverified", "possible_sources", "recommended_follow_up"],
        "additionalProperties": false
      }
    },
    "source_index": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "source_type": { "type": "string", "enum": ["news", "official", "social", "youtube", "other"] },
          "published_at_local": { "type": ["string", "null"] },
          "published_at_utc": { "type": ["string", "null"] },
          "claims_supported": { "type": "array", "items": { "type": "string" } },
          "reliability_notes": { "type": "string" }
        },
        "required": ["label", "url", "source_type", "published_at_local", "published_at_utc", "claims_supported", "reliability_notes"],
        "additionalProperties": false
      }
    },
    "conflicts_or_corrections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "conflicting_values": { "type": "array", "items": { "type": "string" } },
          "preferred_value": { "type": "string" },
          "reasoning": { "type": "string" },
          "sources": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["topic", "conflicting_values", "preferred_value", "reasoning", "sources"],
        "additionalProperties": false
      }
    }
  },
  "required": ["research_window", "summary", "dashboard_patch", "milestones", "timelineEvents", "counter_snapshots", "donations", "unverified_leads", "source_index", "conflicts_or_corrections"],
  "additionalProperties": false,
  "$defs": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "source_type": { "type": "string", "enum": ["news", "official", "social", "youtube", "other"] },
          "published_at_local": { "type": ["string", "null"] },
          "published_at_utc": { "type": ["string", "null"] },
          "quote": { "type": "string" }
        },
        "required": ["label", "url", "source_type", "published_at_local", "published_at_utc", "quote"],
        "additionalProperties": false
      }
    }
  }
}
